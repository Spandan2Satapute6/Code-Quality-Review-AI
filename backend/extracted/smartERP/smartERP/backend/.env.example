SMARTERP_APP_NAME=SmartERP API
SMARTERP_APP_VERSION=1.0.0
SMARTERP_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/smartrp
SMARTERP_DB_ECHO=false
SMARTERP_DB_POOL_SIZE=5
SMARTERP_DB_MAX_OVERFLOW=10
SMARTERP_DB_POOL_RECYCLE=1800
SMARTERP_CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8000
